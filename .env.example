# Brain Guard Environment Variables
# Copy this file to .env and fill in your values

# Plugin Enable/Disable
BRAIN_GUARD_ENABLED=true

# Storage
BRAIN_GUARD_STORAGE_TYPE=sqlite
BRAIN_GUARD_CONNECTION_STRING=~/.openclaw/brain-guard/brain_guard.db

# Embedding Service
BRAIN_GUARD_EMBEDDING_PROVIDER=mock
BRAIN_GUARD_EMBEDDING_DIMENSIONS=128
OPENAI_API_KEY=sk-...

# Dashboard
BRAIN_GUARD_DASHBOARD_ENABLED=true
BRAIN_GUARD_DASHBOARD_HOST=127.0.0.1
BRAIN_GUARD_DASHBOARD_PORT=8080
BRAIN_GUARD_DASHBOARD_AUTH_TOKEN=

# Logging
BRAIN_GUARD_LOG_LEVEL=INFO
