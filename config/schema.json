{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Brain Guard Configuration",
  "description": "Configuration schema for the Brain Guard OpenClaw plugin (formerly SCFL-Observatory)",
  "type": "object",
  "required": ["enabled", "mode"],
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Whether the plugin is active",
      "default": true
    },
    "mode": {
      "type": "string",
      "enum": ["silent", "warn", "strict", "adaptive"],
      "description": "Operating mode for interventions",
      "default": "adaptive"
    },
    "latency": {
      "type": "object",
      "description": "Latency budget and circuit breaker settings",
      "properties": {
        "target_ms": {
          "type": "integer",
          "minimum": 10,
          "maximum": 500,
          "description": "Target processing time per message",
          "default": 50
        },
        "max_ms": {
          "type": "integer",
          "minimum": 50,
          "maximum": 1000,
          "description": "Maximum allowed processing time before circuit breaker",
          "default": 100
        },
        "circuit_breaker_threshold": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 1.0,
          "description": "Percentage of requests exceeding max_ms before circuit opens",
          "default": 0.95
        },
        "async_metrics": {
          "type": "boolean",
          "description": "Compute expensive metrics asynchronously",
          "default": true
        }
      },
      "default": {}
    },
    "thresholds": {
      "type": "object",
      "description": "SCFL-Quad threshold values",
      "properties": {
        "drift_warning": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "ΔG threshold for drift warning (yellow)",
          "default": 0.65
        },
        "rupture_alert": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "ΔG threshold for rupture alert (red)",
          "default": 0.85
        },
        "drift_velocity": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Vd threshold for accelerating drift alert",
          "default": 0.10
        },
        "variance_collapse": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "σ²c threshold for mode collapse detection",
          "default": 0.02
        },
        "recoverability": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "R threshold for low recoverability",
          "default": 0.30
        },
        "ambiguity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Input ambiguity threshold for preprocessing",
          "default": 0.70
        }
      },
      "default": {}
    },
    "monitoring": {
      "type": "object",
      "description": "Monitoring level and escalation settings",
      "properties": {
        "default_level": {
          "type": "string",
          "enum": ["light", "full"],
          "description": "Default monitoring intensity",
          "default": "light"
        },
        "escalation_turns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Number of turns before escalating to full monitoring",
          "default": 10
        },
        "high_stakes_keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords that trigger full monitoring immediately",
          "default": [
            "medical", "health", "diagnosis", "prescription",
            "legal", "contract", "agreement", "liability",
            "financial", "investment", "tax", "account",
            "security", "password", "credential", "private key"
          ]
        },
        "deescalation_turns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "Turns of stability before deescalating",
          "default": 5
        }
      },
      "default": {}
    },
    "embedding": {
      "type": "object",
      "description": "Embedding model configuration",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["openai", "local", "hybrid", "mock"],
          "description": "Embedding service provider",
          "default": "local"
        },
        "model": {
          "type": "string",
          "description": "Specific model name",
          "default": "text-embedding-3-small"
        },
        "dimensions": {
          "type": "integer",
          "minimum": 64,
          "maximum": 3072,
          "description": "Embedding vector dimensions",
          "default": 1536
        },
        "cache_enabled": {
          "type": "boolean",
          "description": "Cache embeddings for repeated content",
          "default": true
        },
        "cache_ttl_seconds": {
          "type": "integer",
          "minimum": 60,
          "maximum": 86400,
          "description": "Embedding cache time-to-live",
          "default": 3600
        },
        "fallback_to_string_sim": {
          "type": "boolean",
          "description": "Use string similarity if embedding fails",
          "default": true
        }
      },
      "default": {}
    },
    "anchoring": {
      "type": "object",
      "description": "Session anchor extraction and management",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable anchor extraction",
          "default": true
        },
        "max_anchors": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200,
          "description": "Maximum anchors per session",
          "default": 50
        },
        "contradiction_check": {
          "type": "boolean",
          "description": "Check new responses against existing anchors",
          "default": true
        },
        "contradiction_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Similarity threshold for contradiction detection",
          "default": 0.85
        },
        "anchor_types": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Types of anchors to extract",
          "default": ["factual", "procedural", "contextual", "temporal"]
        }
      },
      "default": {}
    },
    "interventions": {
      "type": "object",
      "description": "Intervention behavior settings",
      "properties": {
        "auto_regenerate": {
          "type": "boolean",
          "description": "Automatically regenerate on rupture",
          "default": false
        },
        "max_regenerations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum regeneration attempts per turn",
          "default": 2
        },
        "user_confirmation_for_halt": {
          "type": "boolean",
          "description": "Request user confirmation before halting",
          "default": true
        },
        "fallback_message": {
          "type": "string",
          "description": "Message shown when entering fallback mode",
          "default": "I'm having trouble maintaining coherence. Let me try a more careful approach."
        }
      },
      "default": {}
    },
    "storage": {
      "type": "object",
      "description": "Database and persistence settings",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sqlite", "postgresql"],
          "description": "Database type",
          "default": "sqlite"
        },
        "connection_string": {
          "type": "string",
          "description": "Database connection string",
          "default": "~/.openclaw/scfl.db"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365,
          "description": "Days to retain raw metrics",
          "default": 30
        },
        "aggregation_retention_days": {
          "type": "integer",
          "minimum": 30,
          "maximum": 1825,
          "description": "Days to retain aggregated statistics",
          "default": 365
        },
        "batch_size": {
          "type": "integer",
          "minimum": 10,
          "maximum": 1000,
          "description": "Batch size for metric writes",
          "default": 100
        },
        "write_interval_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 10000,
          "description": "Interval for flushing metrics to DB",
          "default": 1000
        }
      },
      "default": {}
    },
    "dashboard": {
      "type": "object",
      "description": "Dashboard API and UI settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable dashboard API",
          "default": true
        },
        "port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "description": "Dashboard server port",
          "default": 8080
        },
        "host": {
          "type": "string",
          "description": "Dashboard bind address",
          "default": "127.0.0.1"
        },
        "auth_required": {
          "type": "boolean",
          "description": "Require authentication for dashboard",
          "default": true
        },
        "auth_token": {
          "type": "string",
          "description": "Dashboard access token (auto-generated if empty)",
          "default": ""
        },
        "cors_origins": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed CORS origins",
          "default": ["http://localhost:3000"]
        },
        "max_sessions_list": {
          "type": "integer",
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum sessions in list endpoint",
          "default": 100
        }
      },
      "default": {}
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "description": "Log level",
          "default": "info"
        },
        "log_interventions": {
          "type": "boolean",
          "description": "Log all interventions",
          "default": true
        },
        "log_metrics": {
          "type": "boolean",
          "description": "Log all metric calculations",
          "default": false
        },
        "log_file": {
          "type": "string",
          "description": "Log file path (empty = stdout only)",
          "default": ""
        }
      },
      "default": {}
    },
    "testing": {
      "type": "object",
      "description": "Testing and calibration settings",
      "properties": {
        "mock_embeddings": {
          "type": "boolean",
          "description": "Use deterministic mock embeddings",
          "default": false
        },
        "calibration_mode": {
          "type": "boolean",
          "description": "Collect extra data for threshold calibration",
          "default": false
        },
        "a_b_test_enabled": {
          "type": "boolean",
          "description": "Enable A/B testing of interventions",
          "default": false
        }
      },
      "default": {}
    }
  },
  "additionalProperties": false
}
